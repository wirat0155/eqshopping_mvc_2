@{
    ViewData["Title"] = "ประวัติการสแกน";
}

<div class="card shadow-sm">
    <div class="card-body d-flex align-items-center justify-content-center text-white" style="background-color: cornflowerblue">
        <h1>ประวัติการสแกน</h1>
    </div>
</div>

<div class="card mt-3">
    <div class="card-body">
        <form id="searchForm">
            <div class="row mb-3">
                <div class="col-md-3">
                    <label class="form-label">Mode</label>
                    <select class="form-select" id="cbo_mode" name="mode">
                        <option value="EQS" selected>EQ Shopping</option>
                        <option value="ASSY">Final Assy</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Scan Date From</label>
                    <input type="date" class="form-control" name="startDate" value="@DateTime.Now.AddMonths(-1).ToString("yyyy-MM-dd")">
                </div>
                <div class="col-md-3">
                    <label class="form-label">To</label>
                    <input type="date" class="form-control" name="endDate" value="@DateTime.Now.ToString("yyyy-MM-dd")">
                </div>
                <div class="col-md-3">
                    <label class="form-label">POS No (comma separated)</label>
                    <input type="text" class="form-control" name="posNos" placeholder="U26xxxxxxxx, U26xxxxxxx">
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-md-3">
                    <label class="form-label">Part No (comma separated)</label>
                    <input type="text" class="form-control" name="partNos" placeholder="898xxxxxx, 897xxxxx">
                </div>
                <div class="col-md-3" id="div_cell_no">
                    <label class="form-label">Cell No (comma separated)</label>
                    <input type="text" class="form-control" name="cellNos" placeholder="C1, C2">
                </div>
                <div class="col-md-6 d-flex align-items-end gap-2">
                    <button type="button" class="btn btn-primary w-25" id="btnSearch">Search</button>
                    <button type="button" class="btn btn-success w-25" id="btnExport">Export Excel</button>
                    <button type="reset" class="btn btn-secondary">Reset</button>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card mt-3">
    <div class="card-body">
         <div class="table-responsive">
            <table id="historyTable" class="table table-striped table-bordered" style="width:100%">
                <thead>
                    <tr>
                        <th>Tran ID</th>
                        <th>Plant No</th>
                        <th>POS No</th>
                        <th>Part No</th>
                        <th>Cell No</th>
                        <th>Finish Date</th>
                        <th>Start Check User</th>
                        <th>Seq No</th>
                        <th>Equip No</th>
                        <th>Check Date</th>
                        <th>Check User</th>
                    </tr>
                </thead>
            </table>
         </div>
    </div>
</div>
<div class="d-flex justify-content-center mt-3">
     <a asp-controller="MainMenu" asp-action="vList" class="btn w-25 text-white" style="background-color: coral">
        เมนูหลัก
    </a>
</div>

@section Scripts {
    <script src="~/js/History/vSearch.js" asp-append-version="true"></script>
}
