<div class="card shadow-sm">
    <div class="card-body d-flex align-items-center justify-content-center text-white" style="background-color: darkseagreen">
        <h1>ช้อปปิ้ง</h1>
    </div>
</div>

<form onsubmit="Search(event)">
    <input hidden name="txt_plantno" value="">
    <div class="p-0 my-5" id="form">
        <partial name="_Form" />
    </div>

    <div class="d-flex justify-content-around" id="form1_button">
        <button type="submit" class="btn w-50 fs-2 text-white" style="background-color: darkseagreen" id="btnSearch">
            ค้นหา
        </button>

        <button type="reset" class="btn w-25 fs-4 text-white" style="background-color: hotpink">
            รีเซ็ท
        </button>
    </div>
</form>

<hr />
<div class="d-flex justify-content-around">
    <a class="btn w-50 text-white" style="background-color: orangered" asp-controller="DataManagement" asp-action="vIndex" onclick="return confirm('คุณต้องการเริ่มใหม่หรือไม่?');">
        เริ่มใหม่
    </a>

    <a asp-controller="MainMenu" asp-action="vList" class="btn w-25 text-white" style="background-color: coral" onclick="return confirm('คุณต้องการกลับไปที่เมนูหลักหรือไม่?');">
        เมนูหลัก
    </a>
</div>

@section Scripts {
    <script src="~/js/Shopping/vIndex.js" asp-append-version="true"></script>
    <script>
        $(document).ready(function () {
            // Prevent Enter from submitting the form when used in input fields
            $('form').on('keydown', 'input, select, textarea', function (e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    // Optionally, move focus to next input here
                }
            });

            const triggerFields = ["txt_cellno", "txt_posno"];

            $("[name='txt_plantno']").val(localStorage.getItem("eqs_plantno"));
            // find element with name = 'txt_cellno' then focus it
            const cellInput = $("[name='txt_cellno']");
            if (cellInput.length) {
                cellInput.focus();
            }
        });
    </script>
}