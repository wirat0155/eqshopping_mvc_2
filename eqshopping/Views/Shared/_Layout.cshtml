@inject Microsoft.Extensions.Configuration.IConfiguration Configuration

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />
    <title>@ViewData["Title"] - eqshopping</title>
    <link rel="icon" type="image/png" href="~/themes/dist/img/logomainpage.png">
    <link href="~/css/loader.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/themes/dist/libs/dropzone/dist/dropzone.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/themes/dist/css/tabler.min.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/themes/dist/css/tabler-flags.min.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/themes/dist/css/tabler-socials.min.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/themes/dist/css/tabler-payments.min.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/themes/dist/css/tabler-vendors.min.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/themes/dist/css/tabler-marketing.min.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/themes/dist/css/demo.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/lib/sweetalert2/sweetalert2.min.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/lib/select2/select2.min.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/lib/datatables/dataTables.bootstrap5.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/lib/bootstrap-icon/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        .error.text-danger {
            font-size: 1.5rem;
        }
    </style>

</head>
<body class=" d-flex flex-column">
    <div class="loader-container" id="loader">
        <div class="loader"></div>
    </div>
    <div class="page">
        
        <div class="page-wrapper">
            <div class="page-wrapper">
                <div class="page-body p-3 m-0">
                    @RenderBody()
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/jquery-3.7.1.min.js" asp-append-version="true"></script>
    <script src="~/js/loader.js" asp-append-version="true"></script>
    <script src="~/js/date.js" asp-append-version="true"></script>
    <script src="~/js/function.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/themes/dist/js/tabler.min.js" asp-append-version="true"></script>
    <script src="~/themes/dist/js/demo.min.js" asp-append-version="true"></script>
    <script src="~/lib/datatables/bootstrap.bundle.min.js" asp-append-version="true"></script>
    <script src="~/lib/datatables/dataTables.js" asp-append-version="true"></script>
    <script src="~/lib/datatables/dataTables.bootstrap5.js" asp-append-version="true"></script>
    <script src="~/lib/select2/select2.min.js" asp-append-version="true"></script>
    <script src="~/lib/sweetalert2/sweetalert2.min.js" asp-append-version="true"></script>
    <script>
        window.onload = function () {
            hideLoader();
            preventBackForward();
        }
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>