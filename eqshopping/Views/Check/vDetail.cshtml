@using eqshopping.Controllers
@model CheckController.vDetailFM;
<div class="card shadow-sm">
    <div class="card-body d-flex align-items-center justify-content-center text-white" style="background-color: coral">
        <h1>ตรวจสอบ</h1>
    </div>
</div>

<partial name="_Form" model="@Model.obj_header" />

<form onsubmit="Save(event);">
    <input hidden name="txt_plantno" value="">
    <input hidden name="txt_cellno" value="@Model.obj_header.txt_cellno">
    <input hidden name="txt_posno" value="@Model.obj_header.txt_posno">
    <h4 class="text-center">สแกน Equipment</h4>
    <div class="mb-1 row">
        <label class="col-3 col-form-label"><b>Tran ID. : </b></label>
        <div class="col">
            <input class="form-control" disabled value="@Model.obj_tran.tranid">
            <input hidden value="@Model.obj_tran.tranid" name="txt_tranid">
        </div>
    </div>

    <div class="my-1 row">
        <label class="col-3 col-form-label"><b>Part No. :</b></label>
        <div class="col">
            <input class="form-control" disabled value="@Model.txt_partno" id="txtPartNo" />
            <input hidden value="@Model.txt_partno" name="txt_partno" />
        </div>
    </div>

    <div class="my-1 row">
        <label class="col-3 col-form-label"><b>EQ. No. :</b></label>
        <div class="col">
            @if (Model.txt_user.ToUpper() == "PLT3DIS")
            {
                if (@Model.obj_tran.discheckingfinishflag == true)
                {
                    <input class="form-control fs-1 text-center" name="txt_equipmentno" disabled placeholder="สแกนครบแล้ว" />
                }
                else
                {
                    <input class="form-control fs-1 text-center" id="txtEquipmentNo" name="txt_equipmentno" onkeyup="txtEquipmentNo_KeyPress(event);" />
                }
            }
            else
            {
                if (@Model.obj_tran.checkingfinishdate != null)
                {
                    <input class="form-control fs-1 text-center" name="txt_equipmentno" disabled placeholder="สแกนครบแล้ว" />
                }
                else
                {
                    <input class="form-control fs-1 text-center" id="txtEquipmentNo" name="txt_equipmentno" onkeyup="txtEquipmentNo_KeyPress(event);" />
                }
            }

        </div>
    </div>
    <button id="btnSaveSub" type="submit" hidden>Save</button>
</form>


@{
    short i = 0;
}
<div id="table">
    @if (Model.ls_sub.Count > 0)
    {
        <table class="table table-sm">
            <thead>
                <tr>
                    <th>Seq.</th>
                    <th>Task Code</th>
                    <th>EQ.No.</th>
                    <th>Checking Date</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model.ls_sub)
                {
                    <tr>
                        <td>@(++i)</td>
                        <td>@row.taskcode</td>
                        <td>@row.equipmentno</td>

                        <td>
                            @row.checkingdate?.ToString("dd-MM-yyyy")
                            <br />
                            @row.checkingdate?.ToString("HH:mm")
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

</div>

<hr />
<div class="d-flex justify-content-around">
    <a class="btn w-50 text-white" style="background-color: orangered" asp-controller="Check" asp-action="vIndex" onclick="return confirm('คุณต้องการเริ่มใหม่หรือไม่?');">
        เริ่มใหม่
    </a>

    <a asp-controller="MainMenu" asp-action="vList" class="btn w-25 text-white" style="background-color: coral" onclick="return confirm('คุณต้องการกลับไปที่เมนูหลักหรือไม่?');">
        เมนูหลัก
    </a>
</div>

@section Scripts {
    <script src="~/js/Check/vDetail.js" asp-append-version="true"></script>
    <script>
        $(document).ready(function () {
            $('form').on('keydown', 'input, select, textarea', function (e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    // Optionally, move focus to next input here
                }
            });

            $("[name='txt_plantno']").val(localStorage.getItem("eqs_plantno"));
            // if  name="txt_equipmentno" is not disabled, then focus it
            const equipmentInput = $("[name='txt_equipmentno']");
            if (equipmentInput.length && !equipmentInput.is(':disabled')) {
                equipmentInput.focus();
            }
        });
    </script>
}